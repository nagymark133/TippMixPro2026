# Football-Data.org (https://www.football-data.org/)
# Free tier: 10 requests/minute, 12 competitions supported
FOOTBALL_DATA_KEY=your_football_data_org_key_here

# Zhipu AI GLM (https://open.bigmodel.cn/)
ZHIPU_API_KEY=your_zhipu_api_key_here

# Turso / libsql (https://turso.tech/)
# Ha meg van adva, ez az elsodleges adatbazis (lokalis SQLite helyett)
TURSO_DATABASE_URL=libsql://your-db-name-username.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
